#!/usr/bin/bash

help()
{
    echo
    echo "This program will rename music files with the format 'tracknumber - artist - title'."
    echo
    echo "Provide the music files you wish to rename to this program as arguments."
    echo
}

flacFormat()
{
    #store title
    local title="$(metaflac --show-tag=title "$1")"
    #remove first 6 characters from title
    local title="${title:6}"

    #store artist
    local artist="$(metaflac --show-tag=artist "$1")"
    #remove first 7 characters from artist
    local artist="${artist:7}"

    #store tracknumber
    local tracknumber="$(metaflac --show-tag=tracknumber "$1" 2> /dev/null)"
    if [ -n tracknumber ]; then
        local tracknumber="${tracknumber:12}"
    fi

    #create file name
    local name="$(printf "%.2d - %s - %s" "$tracknumber" "$artist" "$title")"
    mv "$1" "$name.flac"
}

mp3Format()
{
    #store title
    local title="$(ffprobe -show_format "$1" 2> /dev/null | grep "title")"
    #remove extra data in title
    local title="${title:10}"

    #store artist
    local artist="$(ffprobe -show_format "$1" 2> /dev/null | grep "^TAG:artist")"
    #remove extra data in artist
    local artist="${artist:11}"

    #store tracknumber
    local tracknumber="$(ffprobe -show_format "$1" 2> /dev/null | grep "track")"
    #remove extra data in tracknumber
    local tracknumber="${tracknumber:10}"

    #create file name
    local name="$(printf "%.2d - %s - %s" "$tracknumber" "$artist" "$title")"
    mv "$1" "$name.mp3"
}

#process options
options="$(getopt -n "nameMusic" -o h -l help -- "$@")"

#put formatted options into commandline options
eval set -- "$options"

while : ; do
    case $1 in
        -h|--help) #print help
            help
            exit;;
        --) #end of options
            shift
            break;;
    esac
done

#main program
#non-zero length arguments?
while [ -n "$1" ]; do

    #not already formatted?
    pat='^[:digit:]{2} - .* - .*\..*$'
    if [[ ! "$1" =~ $pat ]] ; then

        #flac file?
        pat='flac$'
        if [[ "$1" =~ $pat ]] ; then
            flacFormat "$1"
        fi

        #mp3 file?
        pat='mp3$'
        if [[ "$1" =~ $pat ]] ; then
            mp3Format "$1"
        fi
    fi
    #shift to next argument
    shift
done
