#!/usr/bin/bash

main()
{
    #$1 empty?
    if [ -z "$1" ] ; then
        return
    fi
    #$1 a directory?
    if [ -d "$1" ] ; then
        cd "$1"
        echo "Entered dir $1"
        main *
        cd ".."
        echo "Exited dir $1"
    fi
    #not already formatted?
    if [[ ! "$1" =~ $PAT ]] ; then
        #$1 a flac file?
        if [[ "$1" =~ flac$ ]] ; then
            flacFormat "$1"
        fi
        #$1 a mp3 file?
        if [[ "$1" =~ mp3$ ]] ; then
            mp3Format "$1"
        fi
    fi
    shift
    main "$@"
}

help()
{
    echo
    echo "This program will rename music files with the format 'tracknumber - artist - title'."
    echo
    echo "Provide the music files you wish to rename to this program as arguments."
    echo "Also works with directories."
    echo
}

flacFormat()
{
    #store tag information
    local information="$(metaflac --export-tags-to=- "$1")"

    #store title
    local title="$(echo "$information" | grep "^TITLE")"
    #truncate title
    local title="${title:6}"

    #store artist
    local artist="$(echo "$information" | grep "^ARTIST")"
    #truncate artist
    local artist="${artist:7}"

    #store tracknumber
    local tracknumber="$(echo "$information" | grep "^TRACKNUMBER")"
    #truncate tracknumber if exists
    if [ -n tracknumber ]; then
        local tracknumber="${tracknumber:12}"
    fi

    #create file name
    local name="$(printf "%.2d - %s - %s.flac" "$tracknumber" "$artist" "$title")"
    #replace '/'
    local name="$(echo "$name" | sed 's/\//\-/g')"
    mv "$1" "$name"
    echo "Renamed $1 to $name"
}

mp3Format()
{
    #store tag information
    local information="$(ffprobe -show_format 2> /dev/null "$1")"

    #store title
    local title="$(echo "$information" | grep "^TAG:title")"
    #truncate title
    local title="${title:10}"

    #store artist
    local artist="$(echo "$information" | grep "^TAG:artist")"
    #truncate artist
    local artist="${artist:11}"

    #store tracknumber
    local tracknumber="$(echo "$information" | grep "^TAG:track")"
    #truncate tracknumber if exists
    if [ -n tracknumber ]; then
        local tracknumber="${tracknumber:10}"
    fi

    #create file name
    local name="$(printf "%.2d - %s - %s.mp3" "$tracknumber" "$artist" "$title")"
    #replace '/'
    local name="$(echo "$name" | sed 's/\//\-/g')"
    mv "$1" "$name"
    echo "Renamed $1 to $name"
}

#process options
options="$(getopt -n "nameMusic" -o h -l help -- "$@")"

#put formatted options into commandline options
eval set -- "$options"

while true ; do
    case $1 in
        -h|--help) #print help
            help
            exit;;
        --) #end of options
            shift
            break;;
    esac
done

#pattern used to determine if a file is already formatted.
PAT='^[[:digit:]]{2}[[:space:]]\-[[:space:]].*[[:space:]]\-[[:space:]].*\..*$'
main "$@"

