#!/usr/bin/bash

help()
{
	echo
	echo "This program will rename music files with the format 'tracknumber - artist - title'."
	echo
	echo "Provide the music files you wish to rename to this program as arguments."
	echo
}

#process options
while getopts ":h" option; do
	case $option in
		h) #print help
			help
			exit;;
		\?) #invalid option
			echo "Error: Invalid option"
			exit;;
	esac
done

#loop while there are non-zero length arguments
while [ -n "$1" ]; do

	#do if the argument is a flac file
	#and isn't already formatted
	if [[ "$1" =~ '.*\.flac$' ]] ; then
		if [[ ! "$1" =~ '^[:digit:]{2} - .* - .*\.flac$' ]] ; then

			#store title in title
			title="$(metaflac --show-tag=title "$1")"
			title="${title:6}"

			#store artist in artist
			artist="$(metaflac --show-tag=artist "$1")"
			artist="${artist:7}"

			#store number in number, suppress errors
			number=$(metaflac --show-tag=tracknumber "$1" 2> /dev/null)
			if [ -n number ]; then
				number="${number:12}"
			fi

			#create the file name
			name="$(printf "%.2d - %s - %s" "$number" "$artist" "$title")"
			mv "$1" "$name.flac"
		fi
	fi
	shift
done
