#!/usr/bin/bash

help() {
    echo
    echo "This program will rename music files with the format 'tracknumber - artist - title'."
    echo
    echo "Provide the music files you wish to rename to this program as arguments."
    echo "Also works with directories."
    echo
}

main() {
    #is empty?
    if [ -z "$1" ] ; then
        return
    fi
    #is a directory?
    if [ -d "$1" ] ; then
        cd "$1"
        echo "Entered directory \"$1\""
        main *
        cd ".."
        echo "Exited directory \"$1\""
    fi
    #separate old name from directory
    oldName="$(basename "$1")"
    dir="$(echo "$1" | sed s/"$oldName"$//)"

    #is a flac file?
    if [[ "$oldName" =~ flac$ ]] ; then
        flacFormat
    #is a mp3 file?
    elif [[ "$oldName" =~ mp3$ ]] ; then
        mp3Format
    fi
    shift
    main "$@"
}

flacFormat() {
    #store tag information
    information="$(metaflac --export-tags-to=- "$dir""$oldName")"
    format="flac"

    #store title
    title="$(echo "$information" | grep "^TITLE")"
    #truncate title
    title="${title:6}"

    #store artist
    artist="$(echo "$information" | grep "^ARTIST")"
    #truncate artist
    artist="${artist:7}"

    #store tracknumber
    tracknumber="$(echo "$information" | grep "^TRACKNUMBER")"
    #truncate tracknumber if exists
    if [ -n tracknumber ] ; then
        tracknumber="${tracknumber:12}"
    fi
    move
}

mp3Format() {
    #store tag information
    information="$(ffprobe -show_format "$dir""$oldName" 2> /dev/null)"
    format="mp3"

    #store title
    title="$(echo "$information" | grep "^TAG:title")"
    #truncate title
    title="${title:10}"

    #store artist
    artist="$(echo "$information" | grep "^TAG:artist")"
    #truncate artist
    artist="${artist:11}"

    #store tracknumber
    tracknumber="$(echo "$information" | grep "^TAG:track")"
    #truncate tracknumber if exists
    if [ -n tracknumber ] ; then
        tracknumber="${tracknumber:10}"
    fi
    move
}

move() {
    #create file name
    newName="$(printf "%.2d - %s - %s.%s" "$tracknumber" "$artist" "$title" "$format")"

    #handle '/' in file metadata
    newName="$(echo "$newName" | sed 's/\//\-/g')"

    #move file
    if [ "$oldName" != "$newName" ] ; then
        mv "$dir""$oldName" "$dir""$newName" &> /dev/null
        echo "Renamed \"$dir$oldName\" to \"$newName\""
    fi
}

#process options
options="$(getopt -n "nameMusic" -o h -l help -- "$@")"

#put formatted options into commandline options
eval set -- "$options"

while true ; do
    case $1 in
        -h|--help) #print help
            help
            exit;;
        --) #end of options
            shift
            break;;
    esac
done
#initial main funcion call
main "$@"

